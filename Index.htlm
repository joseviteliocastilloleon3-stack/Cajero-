<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Zenith-KO — Caja</title>
<style>
:root{--or:#e87722;--dk:#1a1a1a;--g1:#f8f8f8;--g5:#888;--g6:#555;--ok:#28a745;--er:#dc3545;--in:#0d6efd}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:#f0f0f0;color:var(--dk)}
/* LOGIN */
#login-screen{position:fixed;inset:0;background:var(--dk);display:flex;align-items:center;justify-content:center;z-index:9999;transition:.4s}
#login-screen.out{opacity:0;pointer-events:none}
.l-box{background:#fff;border-radius:16px;padding:36px 32px;width:340px;text-align:center}
.l-logo{font-size:48px;margin-bottom:8px}
.l-brand{font-size:22px;font-weight:800;color:var(--or);letter-spacing:2px}
.l-sub{font-size:12px;color:var(--g5);margin-bottom:24px}
.l-fi{margin-bottom:14px;text-align:left}
.l-lbl{font-size:12px;font-weight:600;color:var(--g6);display:block;margin-bottom:4px}
.l-inp{width:100%;padding:10px 12px;border:1.5px solid #ddd;border-radius:8px;font-size:14px}
.l-btn{width:100%;padding:12px;background:var(--or);color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;margin-top:6px}
.l-err{color:var(--er);font-size:12px;margin-top:8px;display:none}
.l-rol{background:#fff3e0;border:1px solid #ffcc80;border-radius:8px;padding:8px 12px;font-size:12px;color:#e65100;margin-bottom:16px}
/* APP */
#app{display:none;min-height:100vh}
.topbar{background:var(--dk);color:#fff;padding:12px 20px;display:flex;align-items:center;justify-content:space-between}
.topbar-brand{display:flex;align-items:center;gap:10px}
.topbar-brand .ic{font-size:24px}
.topbar-name{font-size:16px;font-weight:800;color:var(--or);letter-spacing:1px}
.topbar-sub{font-size:11px;color:#aaa}
.topbar-right{display:flex;align-items:center;gap:14px}
.tb-user{text-align:right}
.tb-user-name{font-size:13px;font-weight:600}
.tb-user-rol{font-size:11px;color:#aaa}
.btn-logout{background:none;border:1px solid #555;color:#ccc;padding:6px 12px;border-radius:6px;cursor:pointer;font-size:12px}
/* TABS */
.tabs{background:#fff;border-bottom:2px solid #eee;display:flex;padding:0 20px;gap:4px}
.tab{padding:14px 20px;border:none;background:none;cursor:pointer;font-size:14px;font-weight:600;color:var(--g5);border-bottom:3px solid transparent;margin-bottom:-2px;transition:.2s}
.tab.act{color:var(--or);border-bottom-color:var(--or)}
/* CONTENT */
.content{padding:20px;max-width:1100px;margin:0 auto}
.pnl{display:none}.pnl.act{display:block}
/* PEDIDOS */
.kpi-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:20px}
.kd{background:#fff;border-radius:10px;padding:16px;text-align:center;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.kd-v{font-size:22px;font-weight:800;color:var(--or)}
.kd-l{font-size:11px;color:var(--g5);margin-top:4px}
.ped-card{background:#fff;border-radius:10px;padding:16px;margin-bottom:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
.ped-id{font-size:11px;color:var(--g5)}
.ped-items{font-size:14px;font-weight:600;margin:4px 0}
.ped-total{font-size:18px;font-weight:800;color:var(--or)}
.ped-fecha{font-size:11px;color:var(--g5)}
.ped-actions{display:flex;flex-direction:column;gap:6px}
.btn{padding:8px 14px;border:none;border-radius:7px;cursor:pointer;font-size:13px;font-weight:600}
.btn-ok{background:var(--ok);color:#fff}
.btn-er{background:var(--er);color:#fff}
.btn-g{background:#eee;color:var(--dk)}
.badge-pend{background:var(--er);color:#fff;border-radius:50%;width:20px;height:20px;font-size:11px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;margin-left:6px}
/* POS */
.pos-grid{display:grid;grid-template-columns:1fr 340px;gap:16px}
.pos-productos{background:#fff;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.pos-cart{background:#fff;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,.08);position:sticky;top:20px}
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;margin-top:12px}
.prod-btn{border:2px solid #eee;border-radius:10px;padding:12px 8px;cursor:pointer;text-align:center;background:#fff;transition:.2s}
.prod-btn:hover{border-color:var(--or);background:#fff8f3}
.prod-ic{font-size:28px}
.prod-name{font-size:12px;font-weight:700;margin:4px 0 2px}
.prod-price{font-size:14px;font-weight:800;color:var(--or)}
.cart-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #f0f0f0}
.cart-item-name{font-size:13px;font-weight:600}
.cart-item-qty{display:flex;align-items:center;gap:6px}
.qty-btn{width:24px;height:24px;border:1px solid #ddd;border-radius:5px;background:#f5f5f5;cursor:pointer;font-size:14px;font-weight:700}
.cart-totals{margin-top:12px;padding-top:12px;border-top:2px solid #eee}
.cart-row{display:flex;justify-content:space-between;font-size:13px;padding:3px 0}
.cart-row.big{font-size:17px;font-weight:800;color:var(--dk);padding-top:6px}
.btn-cobrar{width:100%;padding:14px;background:var(--or);color:#fff;border:none;border-radius:10px;font-size:16px;font-weight:800;cursor:pointer;margin-top:12px}
.toast{position:fixed;bottom:24px;right:24px;background:#222;color:#fff;padding:12px 20px;border-radius:10px;font-size:13px;z-index:9998;display:none}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="l-box">
    <div class="l-logo">🍗</div>
    <div class="l-brand">ZENITH-KO</div>
    <div class="l-sub">Sistema de Caja · Acceso Restringido</div>
    <div class="l-rol">👤 Solo para personal de caja</div>
    <div class="l-fi"><label class="l-lbl">Usuario</label><input class="l-inp" id="l-user" placeholder="cajero" autocomplete="off"></div>
    <div class="l-fi"><label class="l-lbl">Contraseña</label><input class="l-inp" id="l-pass" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <div class="l-err" id="l-err">Usuario o contraseña incorrectos</div>
    <button class="l-btn" onclick="doLogin()">Ingresar →</button>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <div class="topbar-brand">
      <div class="ic">🍗</div>
      <div><div class="topbar-name">ZENITH-KO</div><div class="topbar-sub">Sistema de Caja</div></div>
    </div>
    <div class="topbar-right">
      <div class="tb-user">
        <div class="tb-user-name">Cajero(a)</div>
        <div class="tb-user-rol">Acceso limitado</div>
      </div>
      <button class="btn-logout" onclick="doLogout()">← Salir</button>
    </div>
  </div>

  <div class="tabs">
    <button class="tab act" onclick="goTab('pedidos',this)">📲 Pedidos Web<span class="badge-pend" id="badge-pend" style="display:none">0</span></button>
    <button class="tab" onclick="goTab('pos',this)">🛒 Caja / POS</button>
  </div>

  <div class="content">
    <!-- PEDIDOS WEB -->
    <div class="pnl act" id="pnl-pedidos">
      <div class="kpi-row">
        <div class="kd"><div class="kd-v" id="kp-pend">0</div><div class="kd-l">Pendientes</div></div>
        <div class="kd"><div class="kd-v" id="kp-conf">0</div><div class="kd-l">Confirmados hoy</div></div>
        <div class="kd"><div class="kd-v" id="kp-tot">S/ 0.00</div><div class="kd-l">Total cobrado hoy</div></div>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:14px">
        <button class="btn btn-g" onclick="cargarPedidos()">🔄 Actualizar</button>
        <span style="font-size:12px;color:var(--g5);align-self:center">Se actualiza cada 2 seg</span>
      </div>
      <div id="lista-pedidos"><div style="text-align:center;color:var(--g5);padding:40px">Sin pedidos pendientes 🍗</div></div>
    </div>

    <!-- POS CAJA -->
    <div class="pnl" id="pnl-pos">
      <div class="pos-grid">
        <div class="pos-productos">
          <div style="font-size:16px;font-weight:700;margin-bottom:4px">🛒 Productos</div>
          <div style="font-size:12px;color:var(--g5)">Toca para agregar al pedido</div>
          <div class="prod-grid" id="prod-grid"></div>
        </div>
        <div class="pos-cart">
          <div style="font-size:15px;font-weight:700;margin-bottom:12px">🧾 Pedido actual</div>
          <div id="cart-items"><div style="color:var(--g5);font-size:13px;text-align:center;padding:20px">Agrega productos 👆</div></div>
          <div class="cart-totals">
            <div class="cart-row"><span>Subtotal (sin IGV)</span><span id="pos-sub">S/ 0.00</span></div>
            <div class="cart-row"><span>IGV (18%)</span><span id="pos-igv">S/ 0.00</span></div>
            <div class="cart-row big"><span>TOTAL</span><span id="pos-tot">S/ 0.00</span></div>
          </div>
          <button class="btn-cobrar" onclick="cobrar()">💰 Cobrar</button>
          <button class="btn btn-g" style="width:100%;margin-top:8px" onclick="limpiarCart()">🗑 Limpiar</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
var SHEETS_URL = 'https://script.google.com/macros/s/AKfycbyuLudU9Fj9Sj1jpxEQ-KuZ9b7PaWijHlYJtMdkCC-gUIlwEUZfQcoYf24bHvNoM--b/exec';
var CRED = {cajero:'caja2026', admin:'zenithko2026'};
var pedTimer;
var cart = [];
var pedidosHoy = JSON.parse(localStorage.getItem('zk_caja_hoy') || '[]');

// LOGIN
function doLogin(){
  var u = document.getElementById('l-user').value.trim();
  var p = document.getElementById('l-pass').value;
  if(CRED[u] && CRED[u]===p){
    document.getElementById('login-screen').classList.add('out');
    setTimeout(function(){ document.getElementById('login-screen').style.display='none'; document.getElementById('app').style.display='block'; },400);
    initApp();
  } else {
    document.getElementById('l-err').style.display='block';
    setTimeout(function(){document.getElementById('l-err').style.display='none';},2000);
  }
}
function doLogout(){ localStorage.removeItem('zk_caja_ses'); location.reload(); }

function initApp(){
  renderProductos();
  cargarPedidos();
  pedTimer = setInterval(cargarPedidos, 2000);
}

// TABS
function goTab(id, btn){
  document.querySelectorAll('.tab').forEach(function(b){b.classList.remove('act');});
  document.querySelectorAll('.pnl').forEach(function(p){p.classList.remove('act');});
  btn.classList.add('act');
  document.getElementById('pnl-'+id).classList.add('act');
}

// PRODUCTOS (mismo catálogo que landing)
var productos = [
  {n:'Alitas BBQ',ic:'🍗',p:20},
  {n:'Alitas Búfalo',ic:'🔥',p:20},
  {n:'Alitas Acevichadas',ic:'🍋',p:20},
  {n:'Alitas Parrilleras',ic:'🥩',p:20},
  {n:'Alitas Extra Picante',ic:'🌶️',p:20},
  {n:'Alitas Maracuyá',ic:'🌼',p:20},
  {n:'Honey Mustard',ic:'🍯',p:20},
  {n:'Combo 12 pzas',ic:'🎉',p:34},
  {n:'Combo 24 pzas',ic:'🏆',p:60}
];

function renderProductos(){
  var g = document.getElementById('prod-grid');
  if(!g) return;
  g.innerHTML = productos.map(function(p,i){
    return '<div class="prod-btn" onclick="addCart('+i+')"><div class="prod-ic">'+p.ic+'</div><div class="prod-name">'+p.n+'</div><div class="prod-price">S/ '+p.p.toFixed(2)+'</div></div>';
  }).join('');
}

function addCart(i){
  var p = productos[i];
  var found = cart.findIndex(function(c){return c.n===p.n;});
  if(found>=0) cart[found].qty++;
  else cart.push({n:p.n,p:p.p,qty:1});
  renderCart();
}

function renderCart(){
  var el = document.getElementById('cart-items');
  if(!el) return;
  if(!cart.length){ el.innerHTML='<div style="color:var(--g5);font-size:13px;text-align:center;padding:20px">Agrega productos 👆</div>'; updateTotales(); return; }
  el.innerHTML = cart.map(function(c,i){
    return '<div class="cart-item"><div><div class="cart-item-name">'+c.n+'</div><div style="font-size:12px;color:var(--g5)">S/ '+c.p.toFixed(2)+' c/u</div></div><div class="cart-item-qty"><button class="qty-btn" onclick="qtyCart('+i+',-1)">−</button><span style="font-weight:700">'+c.qty+'</span><button class="qty-btn" onclick="qtyCart('+i+',1)">+</button></div></div>';
  }).join('');
  updateTotales();
}

function qtyCart(i,d){ cart[i].qty+=d; if(cart[i].qty<=0) cart.splice(i,1); renderCart(); }
function limpiarCart(){ cart=[]; renderCart(); }

function updateTotales(){
  var tot = cart.reduce(function(s,c){return s+c.p*c.qty;},0);
  var base = tot/1.18, igv = tot-base;
  document.getElementById('pos-sub').textContent='S/ '+base.toFixed(2);
  document.getElementById('pos-igv').textContent='S/ '+igv.toFixed(2);
  document.getElementById('pos-tot').textContent='S/ '+tot.toFixed(2);
}

function cobrar(){
  if(!cart.length){showToast('Agrega productos primero');return;}
  var tot = cart.reduce(function(s,c){return s+c.p*c.qty;},0);
  var items = cart.map(function(c){return c.qty+'x '+c.n;}).join(', ');
  if(!confirm('¿Cobrar S/ '+tot.toFixed(2)+' por:\n'+items+'?')) return;
  pedidosHoy.push({id:'POS-'+Date.now(),items:items,total:tot,fecha:new Date().toLocaleString('es-PE')});
  localStorage.setItem('zk_caja_hoy',JSON.stringify(pedidosHoy));
  limpiarCart();
  showToast('✅ Cobrado S/ '+tot.toFixed(2));
}

// PEDIDOS WEB
var pedidosData = [];
function cargarPedidos(){
  var sc = document.createElement('script');
  sc.src = SHEETS_URL+'?callback=recibirPedidos&t='+Date.now();
  document.body.appendChild(sc);
  setTimeout(function(){if(sc.parentNode)sc.parentNode.removeChild(sc);},3000);
}

function recibirPedidos(rows){
  pedidosData = rows.filter(function(r){return r[0]&&r[0]!=='ID'&&r[0]!=='id';});
  renderPedidos();
}

function renderPedidos(){
  var pend = pedidosData.filter(function(r){return (r[6]||'').toLowerCase()==='pendiente';});
  var conf = pedidosData.filter(function(r){return (r[6]||'').toLowerCase()==='confirmado';});
  var totHoy = conf.reduce(function(s,r){return s+parseFloat(r[5]||0);},0);
  document.getElementById('kp-pend').textContent=pend.length;
  document.getElementById('kp-conf').textContent=conf.length;
  document.getElementById('kp-tot').textContent='S/ '+totHoy.toFixed(2);
  var badge=document.getElementById('badge-pend');
  if(pend.length>0){badge.style.display='inline-flex';badge.textContent=pend.length;}else{badge.style.display='none';}
  var el=document.getElementById('lista-pedidos');
  if(!pend.length){el.innerHTML='<div style="text-align:center;color:var(--g5);padding:40px">Sin pedidos pendientes 🍗</div>';return;}
  el.innerHTML=pend.map(function(r){
    return '<div class="ped-card"><div><div class="ped-id">'+r[0]+'</div><div class="ped-items">'+r[2]+'</div><div class="ped-total">S/ '+parseFloat(r[5]||0).toFixed(2)+'</div><div class="ped-fecha">'+r[1]+'</div></div><div class="ped-actions"><button class="btn btn-ok" onclick="confirmarPed(\''+r[0]+'\')">✅ Confirmar</button><button class="btn btn-er" onclick="cancelarPed(\''+r[0]+'\')">✕ Cancelar</button></div></div>';
  }).join('');
}

function confirmarPed(id){
  var sc=document.createElement('script');
  sc.src=SHEETS_URL+'?accion=confirmar&id='+encodeURIComponent(id)+'&callback=noop&t='+Date.now();
  document.body.appendChild(sc);
  setTimeout(function(){if(sc.parentNode)sc.parentNode.removeChild(sc);},2000);
  var r=pedidosData.find(function(x){return x[0]===id;});
  if(r) r[6]='confirmado';
  renderPedidos();
  showToast('✅ Pedido confirmado');
}

function cancelarPed(id){
  if(!confirm('¿Cancelar pedido '+id+'?')) return;
  var sc=document.createElement('script');
  sc.src=SHEETS_URL+'?accion=eliminar&id='+encodeURIComponent(id)+'&callback=noop&t='+Date.now();
  document.body.appendChild(sc);
  setTimeout(function(){if(sc.parentNode)sc.parentNode.removeChild(sc);},2000);
  pedidosData=pedidosData.filter(function(x){return x[0]!==id;});
  renderPedidos();
  showToast('Pedido cancelado');
}

function noop(){}

function showToast(msg){
  var t=document.getElementById('toast');
  t.textContent=msg; t.style.display='block';
  setTimeout(function(){t.style.display='none';},2500);
}
</script>
</body>
</html>
